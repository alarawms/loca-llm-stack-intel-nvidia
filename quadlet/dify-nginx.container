[Unit]
Description=Dify Nginx Reverse Proxy
After=network-online.target

[Container]
Image=docker.io/nginx:alpine
ContainerName=dify-nginx
Pod=dify-stack.pod

Volume=%h/.local/share/ai-models/dify/nginx.conf:/etc/nginx/nginx.conf:Z,ro

# nc (busybox netcat) is more reliable than wget --spider for nginx — avoids
# failing on redirect responses from /setup or /login on first boot
HealthCmd=nc -z localhost 80 || exit 1
HealthInterval=30s
HealthStartPeriod=30s

[Service]
Restart=on-failure
RestartSec=10
TimeoutStartSec=60

[Install]
WantedBy=default.target
