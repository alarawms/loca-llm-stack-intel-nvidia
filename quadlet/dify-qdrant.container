[Unit]
Description=Qdrant Vector Database
After=network-online.target

[Container]
Image=docker.io/qdrant/qdrant:latest
ContainerName=dify-qdrant
Pod=dify-stack.pod

Volume=%h/.local/share/ai-models/qdrant:/qdrant/storage:Z

# qdrant image has bash but no curl/wget/nc — use /dev/tcp TCP check
HealthCmd=bash -c 'echo > /dev/tcp/localhost/6333' || exit 1
HealthInterval=30s
HealthStartPeriod=20s

[Service]
Restart=on-failure
RestartSec=10
TimeoutStartSec=60

[Install]
WantedBy=default.target
